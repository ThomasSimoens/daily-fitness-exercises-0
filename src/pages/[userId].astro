---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const users = await getCollection("users");
  return users.map((user) => ({
    params: { userId: user.data.userId },
    props: { user },
  }));
}

interface Exercise {
  id: string;
  name: string;
  phases: string[];
  primary_muscle_group: string;
  target_muscles: string[];
  movement_pattern: string;
  is_isometric: boolean;
  is_unilateral: boolean;
  plane_of_motion: string;
  equipment_required: string[];
  equipment_optional: string[];
  fatigue_score: number;
  difficulty: string;
  primary_metric: string;
  regression_id: string | null;
  progression_id: string | null;
  reference_urls: Array<{
    label: string;
    url: string;
    type: string;
  }>;
}

interface UserData {
  userId: string;
  displayName: string;
  exercises: Exercise[];
}

interface Props {
  user: {
    data: UserData;
    body: string;
  };
}

interface JournalEntry {
  date: string;
  bullets: string[];
}

const { user } = Astro.props;
const { userId } = Astro.params;

let displayName = "";
let exercises: Exercise[] = [];
let journalEntries: JournalEntry[] = [];
let notFound = false;

if (!user) {
  notFound = true;
} else {
  displayName = user.data.displayName;
  exercises = user.data.exercises;

  // Parse journal log from body: find all ### YYYY-MM-DD sections
  const journalRegex = /### (\d{4}-\d{2}-\d{2})\n([\s\S]*?)(?=\n### |$)/g;
  const entries: JournalEntry[] = [];
  let match;
  while ((match = journalRegex.exec(user.body)) !== null) {
    const date = match[1];
    const bullets = match[2]
      .split("\n")
      .map((l) => l.trim())
      .filter((l) => l.startsWith("- "));
    entries.push({ date, bullets });
  }
  journalEntries = entries;
}

// Get today's date as YYYY-MM-DD
function getTodayDate(): string {
  const d = new Date();
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  const dd = String(d.getDate()).padStart(2, "0");
  return `${yyyy}-${mm}-${dd}`;
}

const todayDate = getTodayDate();
const todayEntry = journalEntries.find((e) => e.date === todayDate);
const todaysExerciseIds = todayEntry
  ? todayEntry.bullets.map((b) => b.replace(/^- /, "").split(":")[0].trim())
  : [];
const todaysExercises = exercises.filter((ex) => todaysExerciseIds.includes(ex.id));

// Most recent 10 journal entries
const recentJournal = journalEntries.slice(-10).reverse();
---

{notFound ? (
  <Base title="User not found">
    <main>
      <h1>User not found</h1>
      <p>No user with ID &ldquo;{userId ?? "unknown"}&rdquo; was found.</p>
    </main>
  </Base>
) : (
  <Base title={`${displayName} - Daily Exercise Tracker`}>
    <main>
      <h1>{displayName}'s Exercise Pool</h1>

      <section>
        <h2>Today's Exercises ({todayDate})</h2>
        {todayEntry ? (
          <ul>
            {todayEntry.bullets.map((bullet) => {
              const text = bullet.replace(/^- /, "");
              const [idPart, ...rest] = text.split(":");
              const ex = exercises.find((e) => e.id === idPart.trim());
              return (
                <li>
                  {ex ? (
                    <>
                      <strong>{ex.name}</strong>: {rest.join(":").trim()}
                    </>
                  ) : (
                    <>{text}</>
                  )}
                </li>
              );
            })}
          </ul>
        ) : (
          <p>No exercises logged for today yet.</p>
        )}
      </section>

      <section>
        <h2>All Exercises ({exercises.length})</h2>
        {exercises.length > 0 ? (
          <ul>
            {exercises.map((ex) => (
              <li>
                <strong>{ex.name}</strong> ({ex.id})
                <ul>
                  <li>Muscle group: {ex.primary_muscle_group}</li>
                  <li>Target muscles: {ex.target_muscles.join(", ")}</li>
                  <li>Movement: {ex.movement_pattern}</li>
                  <li>Difficulty: {ex.difficulty}</li>
                  <li>Fatigue score: {ex.fatigue_score}/5</li>
                  <li>Metric: {ex.primary_metric}</li>
                  <li>Phases: {ex.phases.join(", ")}</li>
                  {ex.is_isometric && <li>Isometric hold</li>}
                  {ex.is_unilateral && <li>Unilateral movement</li>}
                  {ex.equipment_required.length > 0 && (
                    <li>Equipment: {ex.equipment_required.join(", ")}</li>
                  )}
                  {ex.reference_urls.length > 0 && (
                    <li>
                      References:
                      <ul>
                        {ex.reference_urls.map((ref) => (
                          <li>
                            <a href={ref.url} target="_blank" rel="noopener noreferrer">
                              {ref.label} ({ref.type})
                            </a>
                          </li>
                        ))}
                      </ul>
                    </li>
                  )}
                </ul>
              </li>
            ))}
          </ul>
        ) : (
          <p>No exercises defined yet.</p>
        )}
      </section>

      <section>
        <h2>Journal Log</h2>
        {recentJournal.length > 0 ? (
          recentJournal.map((entry) => (
            <div>
              <h3>{entry.date}</h3>
              <ul>
                {entry.bullets.map((bullet) => (
                  <li>{bullet.replace(/^- /, "")}</li>
                ))}
              </ul>
            </div>
          ))
        ) : (
          <p>No journal entries yet.</p>
        )}
      </section>

      <hr />
      <footer>
        <p>
          <a href={`/${userId}`}>Permalink to {displayName}</a>
        </p>
      </footer>
    </main>
  </Base>
)}